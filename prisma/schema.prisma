generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model ContactRequest {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String
  city        String
  state       String
  services    String
  description String
  budget      String
  timeline    String
  createdAt   DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Project {
  id         String   @id @default(cuid())
  title      String
  subtitle   String
  overview   String
  challenge  String
  solution   String
  tags       String
  features   String
  results    String
  logo       String
  websiteUrl String
  slug       String   @unique
  createdAt  DateTime @default(now())
}

model Partner {
  id         String   @id @default(cuid())
  name       String
  logoUrl    String
  websiteUrl String
  createdAt  DateTime @default(now())
}

model Job {
  id             String           @id @default(cuid())
  title          String
  description    String
  department     String
  locationType   String
  employmentType String
  salaryRange    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  applications   JobApplication[]
}

model JobApplication {
  id           String   @id @default(cuid())
  jobId        String
  firstName    String
  lastName     String
  email        String
  phone        String
  linkedinUrl  String?
  portfolioUrl String?
  message      String
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  resumeUrl    String?
  job          Job      @relation(fields: [jobId], references: [id])
}
